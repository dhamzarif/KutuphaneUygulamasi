@model IEnumerable<KutuphaneUygulamasi.Models.Book>

<h2>Kitap Listesi</h2>
<a asp-action="Add" class="btn btn-primary mb-3">Yeni Kitap Ekle</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Başlık</th>
            <th>Yazar</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Price</td>
                <td>@book.Stock</td>
                <td>
                    <a asp-action="Update" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Güncelle</a>
                    <a asp-action="Remove" asp-route-id="@book.Id" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?');">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>